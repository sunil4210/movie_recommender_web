{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Web (Chrome :3000)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "args": [
        "--web-port=3000",
        "--web-hostname=localhost"
      ]
    },
    {
      "name": "Flutter Web (Chrome :3000, profile)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "flutterMode": "profile",
      "args": [
        "--web-port=3000",
        "--web-hostname=localhost"
      ]
    }
  ]
}
